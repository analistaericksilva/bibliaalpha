# Biblia Alpha — Cache Control para Hostinger/LiteSpeed (v3)

# ─── LiteSpeed: desabilitar cache do LSCache para arquivos criticos ──────────────
<IfModule LiteSpeed>
  <FilesMatch "^(index\.html|sw\.js|manifest\.json)$">
    Header always set X-LiteSpeed-Cache-Control "no-cache"
    Header always set X-LiteSpeed-Purge "all"
  </FilesMatch>
</IfModule>

# ─── Headers de cache — Apache mod_headers ────────────────────────────────────
<IfModule mod_headers.c>

  # Assets com hash Vite (imutaveis): cache longo
  # NOTA: sw.js nao tem hash no nome — sera sobrescrito abaixo
  <FilesMatch "\.(js|css|woff2?|ttf|eot)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Imagens: cache de 1 dia
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
    Header always set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # index.html + manifest: sempre buscar versao nova
  # (vem APOS a regra geral .js para garantir override)
  <FilesMatch "^(index\.html|manifest\.json)$">
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
    Header always set X-LiteSpeed-Cache-Control "no-cache"
  </FilesMatch>

  # sw.js: NUNCA cachear — browser precisa detectar updates do SW
  # DEVE ser a ULTIMA regra .js para sobrescrever a regra geral acima
  <Files "sw.js">
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
    Header always set Content-Type "application/javascript"
    Header always set X-LiteSpeed-Cache-Control "no-cache"
  </Files>

</IfModule>

# ─── Compressao Gzip ────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
  AddOutputFilterByType DEFLATE application/json application/manifest+json
</IfModule>

# ─── SPA Routing (React Router) ─────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/assets/
  RewriteCond %{REQUEST_URI} !\.(js|css|png|jpg|jpeg|gif|webp|svg|ico|woff2?|ttf|eot|json)$

  RewriteRule ^ index.html [L]
</IfModule>
