{
  "hosting": {
    "site": "sentinela-ai-489015",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/",
        "headers": [
          {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"},
          {"key": "Pragma", "value": "no-cache"},
          {"key": "Expires", "value": "0"}
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {"key": "Cac?e-Control", "value": "public, max-age=31536000, immutable"}
        ]
      }
    ]
  },
  "firestore": {
    "database": "ai-studio-d00d75cd-ea9b-4bf1-9db1-7ac14eff586f",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
