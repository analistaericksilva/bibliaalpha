rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    function isSignedIn() { return request.auth != null; }
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email_verified == true && request.auth.token.email == 'analista.ericksilva@gmail.com';
    }
    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    function isApprovedUser() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved');
    }
    function isValidUser(data, isCreate) {
      let hasRequiredKeys = isCreate ? (data.keys().hasAll(['email', 'nome', 'foto', 'status', 'createdAt', 'updatedAt']) && data.keys().size() <= 7) : true;
      let validEmail = data.get('email', '') is string && data.get('email', '').size() <= 100;
      let validNome = data.get('nome', '') is string && data.get('nome', '').size() <= 100;
      let validFoto = data.get('foto', '') is string && data.get('foto', '').size() <= 1000;
      let validStatus = data.get('status', '') in ['pending', 'approved', 'blocked'];
      let validAdminField = !('isAdmin' in data) || data.isAdmin is bool;
      return hasRequiredKeys && validEmail && validNome && validFoto && validStatus && validAdminField;
    }
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming(), true) && incoming().email == request.auth.token.email && incoming().status == 'pending' && (!('isAdmin' in incoming()) || incoming().isAdmin == false || isSuperAdmin()) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidUser(incoming(), false) && ((isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'isAdmin', 'updatedAt']) && incoming().updatedAt == request.time) || (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['nome', 'foto', 'updatedAt']) && incoming().updatedAt == request.time));
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }
  }
}
